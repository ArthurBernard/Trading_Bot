# Byte-compiled / caches
__pycache__/
*.py[cod]
*.so
.cache/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Build / packaging
build/
dist/
*.egg-info/
env/
.venv/
.python-version

# Coverage
.coverage
htmlcov/
coverage.xml

# Secrets & runtime config (never commit)
.env
*.key
secrets/
general_config.yaml
id_timestamp
_README.md

# Runtime state — engine SQLite books + local dccd data (a config's db_path /
# data_path, e.g. ./var/*.sqlite, ./var/dccd). Generated by runs, never committed.
var/
*.sqlite

# Deployment manifests — the dashboard's control-plane manifest (default
# configs/dashboard.yaml) and any strategy-deployment config the UI writes.
# These are deployment/strategy content (a signal ref + venue/mode/capital/
# universe), LOCAL-ONLY like strategies/; never committed to the engine repo.
configs/

# Logs / data / notebooks
*.log
*.db
*.dat
*.ipynb_checkpoints
logs/
errors/
# (no blanket *.html ignore — the web UI ships Jinja2 templates under
#  trading_bot/interfaces/ui/templates/ that MUST be tracked.)

# Sphinx generated
doc/source/generated/
doc/build/
doc/_build/

# Archived (pre-rewrite) developer docs — local snapshot, not tracked
doc/dev/_archive/

# Local-only scratch
dev_test/
old_scripts/
deprecated*

# Real strategies are LOCAL-ONLY — never pushed (strategy IP lives outside the
# engine repo; the engine stays generic). Everything under strategies/ is
# ignored EXCEPT the tracked generic example templates.
strategies/*
!strategies/__init__.py
!strategies/README.md
!strategies/example/
!strategies/another_example/
